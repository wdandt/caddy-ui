# Caddy Cloudflare API Token for DNS challenge (optional)
CLOUDFLARE_API_TOKEN=

# Cloudflared Tunnel Token
CLOUDFLARE_TUNNEL_TOKEN=

# Fallback Admin Credentials (used to initialize the database)
ADMIN_USER=admin
ADMIN_PASS=caddyui_admin_secure_pass_123

# JWT Secret Key (for session encryption)
# You can generate one with: openssl rand -hex 32
JWT_SECRET=

# OIDC/SSO Configuration (optional, can also be configured on the UI settings)
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=

# Multi-domain SSO Configuration (optional)
# The public absolute URL of your Caddy UI dashboard (e.g. https://sso.yourdomain.com)
SSO_PORTAL_URL=
# The shared parent domain for SSO session cookies (e.g. .yourdomain.com)
COOKIE_DOMAIN=
